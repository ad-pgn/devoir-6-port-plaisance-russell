<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h2>👥 Détail de l'utilisateur</h2>
  <a href="/users" class="btn btn-secondary">← Retour</a>
</div>

<div class="card">
  <div class="card-body">
    <table class="table">
      <tr>
        <th>Nom d'utilisateur</th>
        <td><%= user.username %></td>
      </tr>
      <tr>
        <th>Email</th>
        <td><%= user.email %></td>
      </tr>
      <tr>
        <th>Créé le</th>
        <td><%= new Date(user.createdAt).toLocaleDateString('fr-FR') %></td>
      </tr>
    </table>

    <div class="mt-3">
      <a href="/users/<%= user.email %>/edit" class="btn btn-warning">✏️ Modifier</a>
      <form action="/users/<%= user.email %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Supprimer cet utilisateur ?')">
        <button type="submit" class="btn btn-danger">🗑 Supprimer</button>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>