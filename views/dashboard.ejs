<%- include('partials/header') %>

<div class="row">
  <!-- Sidebar -->
  <div class="col-md-3">
    <div class="card">
      <div class="card-header bg-primary text-white">
        <h5 class="mb-0">Menu</h5>
      </div>
      <div class="list-group list-group-flush">
        <a href="/catways" class="list-group-item list-group-item-action">⚓ Catways</a>
        <a href="/catways" class="list-group-item list-group-item-action">📅 Réservations</a>
        <a href="/users" class="list-group-item list-group-item-action">👥 Utilisateurs</a>
        <a href="/api-docs" class="list-group-item list-group-item-action">📖 Documentation API</a>
        <a href="/logout" class="list-group-item list-group-item-action text-danger">🚪 Déconnexion</a>
      </div>
    </div>
  </div>

  <!-- Contenu principal -->
  <div class="col-md-9">

    <!-- Infos utilisateur et date -->
    <div class="card mb-4">
      <div class="card-body d-flex justify-content-between align-items-center">
        <div>
          <h4 class="mb-0">Bonjour, <%= user.username %></h4>
          <small class="text-muted"><%= user.email %></small>
        </div>
        <div class="text-end">
          <span class="badge bg-primary fs-6">
            <%= now.toLocaleDateString('fr-FR', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %>
          </span>
        </div>
      </div>
    </div>

    <!-- Réservations en cours -->
    <div class="card">
      <div class="card-header bg-primary text-white">
        <h5 class="mb-0">Réservations en cours</h5>
      </div>
      <div class="card-body">
        <% if (currentReservations.length === 0) { %>
          <p class="text-muted">Aucune réservation en cours.</p>
        <% } else { %>
          <table class="table table-striped table-hover">
            <thead>
              <tr>
                <th>Catway</th>
                <th>Client</th>
                <th>Bateau</th>
                <th>Début</th>
                <th>Fin</th>
              </tr>
            </thead>
            <tbody>
              <% currentReservations.forEach(reservation => { %>
                <tr>
                  <td><%= reservation.catwayNumber %></td>
                  <td><%= reservation.clientName %></td>
                  <td><%= reservation.boatName %></td>
                  <td><%= new Date(reservation.startDate).toLocaleDateString('fr-FR') %></td>
                  <td><%= new Date(reservation.endDate).toLocaleDateString('fr-FR') %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } %>
      </div>
    </div>

  </div>
</div>

<%- include('partials/footer') %>