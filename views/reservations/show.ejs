<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h2>Détail de la réservation</h2>
  <a href="/catways/<%= reservation.catwayNumber %>/reservations" class="btn btn-secondary">← Retour</a>
</div>

<div class="card">
  <div class="card-body">
    <table class="table">
      <tr>
        <th>Catway</th>
        <td><%= reservation.catwayNumber %></td>
      </tr>
      <tr>
        <th>Client</th>
        <td><%= reservation.clientName %></td>
      </tr>
      <tr>
        <th>Bateau</th>
        <td><%= reservation.boatName %></td>
      </tr>
      <tr>
        <th>Début</th>
        <td><%= new Date(reservation.startDate).toLocaleDateString('fr-FR') %></td>
      </tr>
      <tr>
        <th>Fin</th>
        <td><%= new Date(reservation.endDate).toLocaleDateString('fr-FR') %></td>
      </tr>
    </table>

    <div class="mt-3">
      <a href="/catways/<%= reservation.catwayNumber %>/reservations/<%= reservation._id %>/edit" class="btn btn-warning">✏️ Modifier</a>
      <form action="/catways/<%= reservation.catwayNumber %>/reservations/<%= reservation._id %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Supprimer cette réservation ?')">
        <button type="submit" class="btn btn-danger">🗑 Supprimer</button>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>