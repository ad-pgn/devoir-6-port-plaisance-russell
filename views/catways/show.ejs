<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h2>⚓ Détail du catway n°<%= catway.catwayNumber %></h2>
  <a href="/catways" class="btn btn-secondary">← Retour</a>
</div>

<div class="card">
  <div class="card-body">
    <table class="table">
      <tr>
        <th>Numéro</th>
        <td><%= catway.catwayNumber %></td>
      </tr>
      <tr>
        <th>Type</th>
        <td><span class="badge bg-<%= catway.catwayType === 'long' ? 'info' : 'secondary' %>"><%= catway.catwayType %></span></td>
      </tr>
      <tr>
        <th>État</th>
        <td><%= catway.catwayState %></td>
      </tr>
    </table>

    <div class="mt-3">
      <a href="/catways/<%= catway.catwayNumber %>/edit" class="btn btn-warning">✏️ Modifier</a>
      <form action="/catways/<%= catway.catwayNumber %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Supprimer ce catway ?')">
        <button type="submit" class="btn btn-danger">🗑 Supprimer</button>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>