<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h2>⚓ Gestion des catways</h2>
  <div>
    <a href="/dashboard" class="btn btn-secondary me-2">← Tableau de bord</a>
    <a href="/catways/create" class="btn btn-primary">+ Nouveau catway</a>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <table class="table table-striped table-hover">
      <thead class="table-primary">
        <tr>
          <th>Numéro</th>
          <th>Type</th>
          <th>État</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% catways.forEach(catway => { %>
          <tr>
            <td><%= catway.catwayNumber %></td>
            <td><span class="badge bg-<%= catway.catwayType === 'long' ? 'info' : 'secondary' %>"><%= catway.catwayType %></span></td>
            <td><%= catway.catwayState %></td>
            <td>
              <a href="/catways/<%= catway.catwayNumber %>/reservations" class="btn btn-sm btn-success">📅 Réservations</a>
              <a href="/catways/<%= catway.catwayNumber %>" class="btn btn-sm btn-info">👁 Détail</a>
              <a href="/catways/<%= catway.catwayNumber %>/edit" class="btn btn-sm btn-warning">✏️ Modifier</a>
              <form action="/catways/<%= catway.catwayNumber %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Supprimer ce catway ?')">
                <button type="submit" class="btn btn-sm btn-danger">🗑 Supprimer</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/footer') %>